# ============================================================================
# Social Media Radar — Environment Configuration Example
# ============================================================================
# Copy this file to .env and fill in real values BEFORE running the app.
# NEVER commit .env to version control.
# All values shown are FAKE placeholders — do not use them in production.
# ============================================================================

# Environment — allowed: development | staging | production | test
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://radar:CHANGE_ME_DB_PASSWORD@localhost:5432/social_radar
DATABASE_SYNC_URL=postgresql://radar:CHANGE_ME_DB_PASSWORD@localhost:5432/social_radar

# ----------------------------------------------------------------------------
# Redis  (caching, Celery broker, JWT blacklist)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ----------------------------------------------------------------------------
# Object Storage (MinIO / S3-compatible)
# ----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_BUCKET=radar-content

# ----------------------------------------------------------------------------
# LLM Providers  (at least one key required for inference)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_OPENAI_KEY
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_ANTHROPIC_KEY

# ----------------------------------------------------------------------------
# Embedding Configuration
# ----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=1536

# ----------------------------------------------------------------------------
# LLM Configuration
# ----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# Local / Offline LLM (Ollama — uncomment to enable)
# ----------------------------------------------------------------------------
# LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b

# ----------------------------------------------------------------------------
# Fine-tuned model (uncomment and set your fine-tune ID to enable routing)
# ----------------------------------------------------------------------------
# FINE_TUNED_MODEL_ID=ft:gpt-4o-mini-2024-07-18:my-org:my-model:abc123

# ----------------------------------------------------------------------------
# Local vLLM endpoint (uncomment if using a self-hosted vLLM server)
# ----------------------------------------------------------------------------
# LOCAL_MODEL_PATH=/path/to/model/weights
# VLLM_ENDPOINT=http://localhost:8001

# ----------------------------------------------------------------------------
# Security — MUST be replaced before going to production
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------------------------
SECRET_KEY=replace-me-with-output-of-secrets.token_urlsafe-32
ENCRYPTION_KEY=replace-me-with-output-of-secrets.token_urlsafe-32

# ----------------------------------------------------------------------------
# JWT Settings
# ----------------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------------------------
# API Server
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
# Comma-separated or JSON-array of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]

# ----------------------------------------------------------------------------
# MCP Server
# ----------------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ----------------------------------------------------------------------------
# Ingestion
# ----------------------------------------------------------------------------
INGESTION_INTERVAL_MINUTES=15
MAX_ITEMS_PER_FETCH=100

# ----------------------------------------------------------------------------
# Content Processing
# ----------------------------------------------------------------------------
MAX_CONTENT_AGE_DAYS=30
CLUSTER_MIN_SIMILARITY=0.7
MAX_CLUSTERS_PER_DIGEST=20

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# Logging  — LOG_LEVEL: DEBUG|INFO|WARNING|ERROR|CRITICAL  LOG_FORMAT: json|plain
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_VIDEO_TRANSCRIPTION=true
ENABLE_AUTO_CLUSTERING=true
ENABLE_PERSONALIZATION=true

