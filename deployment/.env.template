# Environment configuration template for LLM infrastructure
# Copy this file to .env and fill in actual values

# ============================================================================
# API KEYS (REQUIRED)
# ============================================================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# LLM CONFIGURATION
# ============================================================================

# Primary model to use
LLM_PRIMARY_MODEL=gpt-4o

# Fallback models (comma-separated)
LLM_FALLBACK_MODELS=claude-3-5-sonnet-20241022,gpt-4-turbo-2024-04-09

# Enable cost optimization
LLM_ENABLE_COST_OPTIMIZATION=true

# Maximum cost per request (USD)
LLM_MAX_COST_PER_REQUEST=0.10

# Minimum quality tier (1-5, lower is better)
LLM_MIN_QUALITY_TIER=2

# Maximum retries
LLM_MAX_RETRIES=3

# Retry delay (seconds)
LLM_RETRY_DELAY_SECONDS=1.0

# Circuit breaker threshold
LLM_CIRCUIT_BREAKER_THRESHOLD=5

# ============================================================================
# vLLM CONFIGURATION (OPTIONAL - for local models)
# ============================================================================

# vLLM endpoint
VLLM_ENDPOINT=http://localhost:8000

# vLLM model name
VLLM_MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct

# Tensor parallel size (number of GPUs)
VLLM_TENSOR_PARALLEL_SIZE=1

# GPU memory utilization (0.0-1.0)
VLLM_GPU_MEMORY_UTILIZATION=0.9

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/social_media_radar

# PostgreSQL credentials
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=social_media_radar

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================

# Enable Prometheus metrics
PROMETHEUS_ENABLED=true

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=production

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application port
APP_PORT=8000

# Workers (for production)
APP_WORKERS=4

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-secret-key-here

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT expiration (minutes)
JWT_EXPIRATION_MINUTES=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable A/B testing
ENABLE_AB_TESTING=false

# A/B test model A
AB_TEST_MODEL_A=gpt-4o

# A/B test model B
AB_TEST_MODEL_B=claude-3-5-sonnet-20241022

# A/B test traffic split (0.0-1.0)
AB_TEST_TRAFFIC_SPLIT=0.5

# Enable fine-tuning
ENABLE_FINE_TUNING=false

# Enable caching
ENABLE_CACHING=true

# Cache TTL (seconds)
CACHE_TTL=3600

